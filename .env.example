# Cloudflare DNS (scripts/cloudflare-dns-cutover.sh; auto-loaded from .env)
# CLOUDFLARE_API_TOKEN=              # Zone.DNS Edit on borderchess.org
# CLOUDFLARE_ACCOUNT_ID=

# Engine backend (AWS App Runner + Cloudflare Worker deploy scripts)
# API_KEY=                          # generated by server/aws/deploy.sh if unset
# ALERT_EMAIL=you@example.com         # optional CloudWatch 5xx alarm
# AWS_REGION=us-east-1

# Static site (S3 + CloudFront) - from chess-border-static stack
# CHESS_STATIC_BUCKET=borderchess-static-731049002088
# CHESS_STATIC_CF_DISTRIBUTION_ID=E123ABCDEF
# ENABLE_WAF=true                     # deploy-static.sh - WAF rate limit on /v1/move
# WAF_RATE_LIMIT=600                  # per IP per 5 min (~120/min)
# WORKER_ORIGIN_DOMAIN=chess-engine.sahasraranjan.workers.dev

# Optional CDN overrides (defaults: same-origin /ChessBorder/pieces/ on borderchess.org)
# VITE_PIECE_CDN_URL=https://borderchess.org/ChessBorder/pieces/

# Legacy Brain bucket (publish-pieces.sh only; prefer sync-s3-static.sh)
# CHESS_DOWNLOAD_URL=https://dkxinbm7riorm.cloudfront.net
# CHESS_DOWNLOAD_BUCKET=brain-downloads-731049002088
# CHESS_CF_DISTRIBUTION_ID=EC6D5X1HA219F
